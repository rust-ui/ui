{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rust UI",
  "version": "0.1.24",
  "identifier": "com.rust-ui",
  "build": {
    "beforeDevCommand": "cargo leptos watch",
    "devUrl": "http://localhost:4000",
    "beforeBuildCommand": "",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "url": "https://rust-ui.com",
        "title": "Rust UI",
        "width": 1200,
        "height": 800,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "resources": ["offline.html"],
    "iOS": {
      "developmentTeam": "4JGPL5Q5CD"
    }
  }
}
