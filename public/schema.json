    {
      "@type": "FAQPage",
      "@id": "https://rust-ui.com/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is Rust/UI?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Rust/UI is a comprehensive UI component library for building web applications with Leptos (Rust). It provides 60+ production-ready components, reusable hooks, pre-built blocks, and chart components - all built with Rust, Leptos, and Tailwind CSS."
          }
        },
        {
          "@type": "Question",
          "name": "Is Rust/UI free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, Rust/UI is completely free and open source. All components are available under the MIT license for both personal and commercial use."
          }
        },
        {
          "@type": "Question",
          "name": "What frameworks does Rust/UI support?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Rust/UI is built specifically for Leptos 0.8, a Rust web framework. It works seamlessly with Leptos SSR (Server-Side Rendering) and CSR (Client-Side Rendering) modes."
          }
        },
        {
          "@type": "Question",
          "name": "How do I install components?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Install the Rust/UI CLI with 'cargo install rust-ui-cli', then add components using 'cargo rust-ui add [component-name]'. The CLI will copy the component source code directly to your project."
          }
        },
        {
          "@type": "Question",
          "name": "Does Rust/UI support dark mode?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, all components in Rust/UI support dark mode out of the box using Tailwind CSS dark mode classes and CSS variables for theming."
          }
        }
      ]
